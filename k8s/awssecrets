
apiVersion: secrets-store.csi.x-k8s.io/v1
kind: SecretProviderClass
metadata:
  name: aws-secrets
  namespace: stock
spec:
  provider: aws  
  parameters:
    objects: |
      - objectName: "dev/dashboard/mysql"
        objectType: "secretsmanager"
        jmesPath:
          - path: "username"      
            objectAlias: "MYSQL_DATABASE"  
          - path: "password"
            objectAlias: "MYSQL_ROOT_PASSWORD"
          - path: "USER"
            objectAlias: "DB_USER"



